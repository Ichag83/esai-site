# ─── Supabase ─────────────────────────────────────────────────────────────────
# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose this to the browser or commit to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Site / CORS ──────────────────────────────────────────────────────────────
# Canonical URL of your deployment (used for Server Action allowedOrigins)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Extra allowed origins for Server Actions, comma-separated (optional)
# Example: https://preview.your-app.vercel.app,https://staging.your-app.com
NEXT_PUBLIC_ALLOWED_ORIGINS=

# ─── LLM ──────────────────────────────────────────────────────────────────────
# Provider: "openai" or "anthropic"
LLM_PROVIDER=anthropic
LLM_API_KEY=your-llm-api-key
# OpenAI models:     gpt-4o, gpt-4o-mini
# Anthropic models:  claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
LLM_MODEL=claude-sonnet-4-5
