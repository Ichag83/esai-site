    {
      "parameters": {
        "jsCode": "const doc = $json;\nconst text = String($node['Normalize text and hash'].json.content_text_clean || '');\nconst size = 800;\nconst overlap = 120;\nconst chunks = [];\nlet i = 0;\nfor (let start = 0; start < text.length; start += (size - overlap)) {\n  const part = text.slice(start, start + size).trim();\n  if (!part) continue;\n  chunks.push({ json: { org_id: $node['Normalize text and hash'].json.org_id, document_id: doc.id, chunk_index: i++, content_text: part, metadata: { source_name: $node['Normalize text and hash'].json.source_name, source_type: $node['Normalize text and hash'].json.source_type, version: $node['Normalize text and hash'].json.version || 1 }, trace_id: $node['Normalize text and hash'].json.trace_id } });\n}\nreturn chunks.length ? chunks : [{ json: { org_id: $node['Normalize text and hash'].json.org_id, document_id: doc.id, chunk_index: 0, content_text: text, metadata: { source_name: $node['Normalize text and hash'].json.source_name }, trace_id: $node['Normalize text and hash'].json.trace_id } }];"
      },
