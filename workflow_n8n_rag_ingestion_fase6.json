    {
      "parameters": {
        "jsCode": "const supported = ['text','txt','md','markdown','pdf','doc','docx'];\nconst sourceType = String($json.source_type || 'text').toLowerCase();\nconst text = String($json.raw_text || '').replace(/\n{3,}/g,'\\n\\n').trim();\nlet h = 2166136261;\nfor (let i = 0; i < text.length; i++) { h ^= text.charCodeAt(i); h += (h<<1)+(h<<4)+(h<<7)+(h<<8)+(h<<24); }\nconst content_hash = `fnv1a_${(h>>>0).toString(16)}`;\nreturn [{ ...$json, source_type: sourceType, content_text_clean: text, content_hash, extraction_supported: supported.includes(sourceType), extraction_note: supported.includes(sourceType) ? 'ok' : 'unsupported_source_type' }];"
      },
