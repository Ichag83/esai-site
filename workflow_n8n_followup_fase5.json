            {
              "leftValue": "={{ ['stage1','stage2'].includes($json.followup_action) }}",
              "rightValue": "true",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
