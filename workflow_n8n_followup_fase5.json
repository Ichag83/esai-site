    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst lb = $json.last_outbound_at ? new Date($json.last_outbound_at) : null;\nif (!lb) return [{ ...$json, followup_action: 'skip_no_outbound' }];\nconst h = (now - lb) / 36e5;\nconst stage = Number($json.followup_stage || 0);\nlet followup_action = 'skip_not_due';\nlet next_followup_at = $json.next_followup_at || null;\nif (stage < 1 && h >= 24) { followup_action = 'stage1'; next_followup_at = new Date(now.getTime() + 24*36e5).toISOString(); }\nelse if (stage < 2 && h >= 48) { followup_action = 'stage2'; next_followup_at = null; }\nreturn [{ ...$json, followup_action, next_followup_at, trace_id: `${$json.org_id || 'org'}:${$json.channel_id || 'chan'}:${$json.phone || 'phone'}:${Date.now()}` }];"
      },
